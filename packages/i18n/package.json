{
  "name": "@huifer/i18n",
  "version": "0.0.1",
  "description": "Internationalization utilities for TanStack apps. JSON-based translations, language detection, and hreflang helpers.",
  "keywords": ["i18n", "internationalization", "translation", "locale", "tanstack"],
  "homepage": "https://tanstackship.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/orgs/tanstackship",
    "directory": "packages/i18n"
  },
  "license": "MIT",
  "author": { "name": "Huifer", "url": "https://tanstackship.com/about" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
