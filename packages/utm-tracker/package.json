{
  "name": "@huifer/utm-tracker",
  "version": "1.0.0",
  "description": "UTM tracking & attribution system for web apps. Capture, store, and resolve UTM parameters with first-touch and last-touch support.",
  "keywords": [
    "utm",
    "tracking",
    "attribution",
    "analytics",
    "marketing",
    "tanstack"
  ],
  "homepage": "https://tanstackship.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/orgs/tanstackship",
    "directory": "packages/utm-tracker"
  },
  "license": "MIT",
  "author": {
    "name": "Huifer",
    "url": "https://tanstackship.com/about"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client.ts src/server.ts --format cjs,esm --dts --clean",
    "test": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
