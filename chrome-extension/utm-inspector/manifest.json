{
  "manifest_version": 3,
  "name": "UTM Inspector",
  "version": "1.0.0",
  "description": "Debug and inspect UTM parameters on any webpage",
  "author": "Huifer <about@tanstackship.com>",
  "homepage_url": "https://tanstackship.com",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
